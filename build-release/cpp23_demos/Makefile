# target to preprocess a source file
src/ref.cpp.i:
	cd /Users/tanchangyue/comp/extra_currecular/Projects/Learn-Cpp/build-release && $(MAKE) $(MAKESILENT) -f cpp23_demos/CMakeFiles/cpp23_ref.dir/build.make cpp23_demos/CMakeFiles/cpp23_ref.dir/src/ref.cpp.i
.PHONY : src/ref.cpp.i

src/ref.s: src/ref.cpp.s
.PHONY : src/ref.s

# target to generate assembly for a file
src/ref.cpp.s:
	cd /Users/tanchangyue/comp/extra_currecular/Projects/Learn-Cpp/build-release && $(MAKE) $(MAKESILENT) -f cpp23_demos/CMakeFiles/cpp23_ref.dir/build.make cpp23_demos/CMakeFiles/cpp23_ref.dir/src/ref.cpp.s
.PHONY : src/ref.cpp.s

